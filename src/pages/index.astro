---
import Base from '../layouts/Base.astro';
import { site } from '../data/site';
import { serviceAreaCities } from '../data/cities';
import ReviewsWidget from '../components/ReviewsWidget.astro';
import MapEmbed from '../components/MapEmbed.astro';
import { website, localBusiness } from '../lib/schema';

const title = 'Equipment & Trailer Rental in Denver, CO | The Boyz Rentals';
const description =
  'Firefighter-owned equipment & trailer rental and hauling across Denver & the Front Range. We deliver. Honest pricing. Reserve online or call (303) 900-8228.';
---
<Base
  title={title}
  description={description}
  canonical="/"
  navActive="/"
  jsonLd={[website(), localBusiness()]}
  preloadImage="/assets/denver-hauling.webp"
>
  <!-- ============ HERO ============ -->
  {/* TODO(owner): swap denver-hauling.webp for a wider/higher-res hero shot when available. */}
  <section class="hero" id="top">
    <img class="hero-media" src="/assets/denver-hauling.webp" width="1000" height="750" alt="Excavator being hauled on a trailer in the Denver area" fetchpriority="high" />
    <div class="heroscrim"></div>
    <div class="wrap herorow">
      <div class="heroglass">
        <div class="eyebrow">DENVER, CO · SERVING THE FRONT RANGE</div>
        <h1 class="hhero" style="font-size:60px;margin-top:16px">Trailers, equipment<br>&amp; hauling.<br><span style="color:var(--red)">Firefighter owned.</span></h1>
        <p class="sub" style="font-size:19px;max-width:500px;margin-top:18px">Trailer &amp; equipment rental and load hauling across Denver and the Front Range. Reserve in two minutes &mdash; or just call. <b style="color:#fff">We deliver.</b></p>
        <div class="fx ac gap14 fwrap" style="margin-top:26px">
          <a class="btn btn-red btn-lg" href={site.booking}>Rent Equipment →</a>
          <a class="btn btn-ghost btn-lg" href={site.booking}>Rent Trailers →</a>
        </div>
        <a class="tel" href={site.phoneHref} style="margin-top:18px;font-size:25px"><small>or call</small>{site.phone}</a>
      </div>
    </div>
  </section>

  <!-- ============ REVIEWS ============ -->
  <section class="sec" id="reviews"><div class="wrap">
    <div class="rvhead">
      <div><div class="kick">What our customers say</div><h2 class="h2">Trusted across the Front Range</h2></div>
      <div class="gpill">
        <span class="gbadge">G</span>
        <div>
          <div class="fx ac gap8"><span class="os" style="font-size:22px;font-weight:700;line-height:1">{site.reviews.rating}</span><span class="stars" style="font-size:17px" aria-hidden="true">★★★★★</span></div>
          <div class="rvmeta">{site.reviews.count} Google reviews</div>
        </div>
      </div>
    </div>

    <ReviewsWidget />

    <div class="fx jc" style="margin-top:34px"><a class="btn btn-dark" href={site.booking}>Book Your Rental →</a></div>
  </div></section>

  <!-- ============ SEO PROSE: what we rent ============ -->
  <section class="sec secpaper"><div class="wrap prose">
    <div class="kick">Trailer &amp; Equipment Rental in Denver, CO</div>
    <h2 class="h2" style="margin-bottom:22px">Rugged gear, honest prices, delivered to your job site.</h2>
    <p class="seop"><b>The Boyz Rentals &amp; Towing</b> is a firefighter-founded, owned, and operated equipment and trailer rental company based in Wheat Ridge, Colorado. We started this business to serve our neighbors the way we serve our community on the job &mdash; with straight answers, fair prices, and gear that&rsquo;s ready to work. We aren&rsquo;t in this to get rich and retire. We&rsquo;re in this to serve you.</p>
    <p class="seop">From weekend projects to full job sites, we rent the equipment that gets dirt moving and loads hauled across the entire Denver metro and Front Range. First responder, military, and business discounts are always available &mdash; and because moving heavy gear is half the battle, <b>we deliver</b> straight to your site.</p>
    <h3 class="seoh3">What we rent</h3>
    <ul class="featlist">
      <li><span class="cross mk" aria-hidden="true"></span><span><b><a href="/trailer-rental/" style="color:var(--red);text-decoration:none">Trailers</a></b> &mdash; dump trailers, flatbed &amp; equipment trailers, and car haulers for hauling dirt, debris, a machine, or a vehicle.</span></li>
      <li><span class="cross mk" aria-hidden="true"></span><span><b><a href="/equipment-rental/" style="color:var(--red);text-decoration:none">Equipment</a></b> &mdash; skid steers, mini excavators, and full-size excavators for grading, digging, demo, and material moving.</span></li>
      <li><span class="cross mk" aria-hidden="true"></span><span><b><a href="/hauling-and-delivery/" style="color:var(--red);text-decoration:none">Hauling &amp; Delivery</a></b> &mdash; if it needs moving, we move it. Load hauling and delivery for anything across the Front Range. You call, we haul.</span></li>
    </ul>
  </div></section>

  <!-- ============ SERVICE AREA ============ -->
  <section class="sec" id="service-area"><div class="wrap">
    <div class="tc" style="max-width:760px;margin:0 auto"><div class="kick">Service Area</div><h2 class="h2">We come to you across Metro Denver.</h2><p class="seop" style="margin-top:14px">We deliver trailers and equipment &mdash; and haul loads &mdash; anywhere within roughly a 40-mile radius of Denver. These are the cities we serve most.</p></div>
    <div class="grid" style="grid-template-columns:1.05fr .95fr;gap:40px;margin-top:44px;align-items:stretch">
      <MapEmbed label="~40-mile delivery radius · Denver metro" />
      <div class="col" style="justify-content:center">
        <div class="seoh3" style="margin-top:0">Cities we serve most</div>
        <div class="arealist">
          {serviceAreaCities.map((c) => (
            c.slug
              ? <a class="arealink" href={`/equipment-rental-${c.slug}/`}><span class="dot" aria-hidden="true"></span>{c.name}</a>
              : <span class="arealink" style="opacity:.85"><span class="dot" aria-hidden="true"></span>{c.name}</span>
          ))}
        </div>
        <p class="rvmeta" style="margin-top:18px;font-size:14px;line-height:1.5">Each priority city has its own service-area page. Don&rsquo;t see your town? If you&rsquo;re near the metro, we&rsquo;ve probably got you &mdash; <a href={site.phoneHref} style="color:var(--red);font-weight:700;text-decoration:none">just call</a>.</p>
      </div>
    </div>
  </div></section>

  <!-- ============ CONVERSION SPINE ============ -->
  <section class="sec secpaper"><div class="wrap">
    <div class="tc"><h2 class="h2" style="margin-bottom:38px">What do you need?</h2></div>
    <div class="grid" style="grid-template-columns:1fr 1fr 1fr;gap:24px">
      <div class="spine"><div class="spineph" style="padding:0;overflow:hidden"><img src="/assets/trailer-rental.webp" width="1000" height="750" loading="lazy" alt="The Boyz Trailers utility trailer loaded with sod, Front Range mountains behind" style="width:100%;height:100%;object-fit:cover" /></div><div style="padding:26px 26px 28px"><div class="spname">Trailer Rental</div><p class="specline" style="margin:10px 0 20px;line-height:1.5">Dump, flatbed &amp; equipment, and car haulers. Daily and weekly.</p><a class="btn btn-dark w100 jc" href="https://rent.tbzrentals.com/">Browse Trailers →</a></div></div>
      <div class="spine"><div class="spineph" style="padding:0;overflow:hidden"><img src="/assets/Denver-Excavator.webp" width="1000" height="750" loading="lazy" alt="Kubota mini excavator staged on a Denver-area street" style="width:100%;height:100%;object-fit:cover" /></div><div style="padding:26px 26px 28px"><div class="spname">Equipment Rental</div><p class="specline" style="margin:10px 0 20px;line-height:1.5">Skid steers, mini &amp; full-size excavators. Delivered.</p><a class="btn btn-dark w100 jc" href="https://rent.tbzrentals.com/">Browse Equipment →</a></div></div>
      <div class="spine"><div class="spineph" style="padding:0;overflow:hidden"><img src="/assets/denver-hauling.webp" width="1000" height="750" loading="lazy" alt="Excavator hauled on a trailer near Denver" style="width:100%;height:100%;object-fit:cover" /></div><div style="padding:26px 26px 28px"><div class="spname">Hauling &amp; Delivery</div><p class="specline" style="margin:10px 0 20px;line-height:1.5">If it needs moving, we move it. Front Range wide.</p><a class="btn btn-red w100 jc" href="https://rent.tbzrentals.com/">Hauling &amp; Delivery →</a></div></div>
    </div>
  </div></section>
</Base>
